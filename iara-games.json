    "height": 2,
    "format": "<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n    .search-container {\n        display: flex;\n        align-items: center;\n        border: 1px solid #00830C;\n        border-radius: 25px;\n        background-color: #F6F6F6;\n        padding: 5px 10px;\n        font-family: 'Nunito', sans-serif !important;\n    }\n\n    .search-container i {\n        color: #00830C;\n        margin-right: 8px;\n    }\n\n    .search-container input {\n        border: none;\n        background: transparent;\n        outline: none;\n        width: 100%;\n        font-size: 16px;\n        font-family: 'Nunito', sans-serif !important;\n    }\n</style>\n\n<div class=\"search-container\">\n    <i class=\"fa fa-search\"></i>\n    <input type=\"text\" placeholder=\"Buscar tópicos\" ng-model=\"searchText\" ng-change=\"send({payload: searchText})\">\n</div>",
