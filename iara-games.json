  {
    "id": "7710e90560314fa2",
    "type": "inject",
    "z": "206bd8fcaa20b9ee",
    "name": "lista de topicos",
    "props": [
      {
        "p": "payload"
      }
    ],
    "repeat": "",
    "crontab": "",
    "once": true,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "[{\"titulo\":\"Discussão geral\",\"subtitulo\":\"Converse sobre qualquer coisa relacionada a jogos\",\"mensagens\":121},{\"titulo\":\"Lançamentos de jogos\",\"subtitulo\":\"Saiba sobre o que vem por aí\",\"mensagens\":95},{\"titulo\":\"Problemas técnicos\",\"subtitulo\":\"Converse sobre problemas técnicos nos jogos\",\"mensagens\":132},{\"titulo\":\"Qual seu jogo favorito?\",\"subtitulo\":\"Compartilhe seus jogos favoritos\",\"mensagens\":47},{\"titulo\":\"Boas-vindas\",\"subtitulo\":\"Sejam bem-vindos ao fórum do Iara Games!\",\"mensagens\":168},{\"titulo\":\"Dicas para iniciantes\",\"subtitulo\":\"Conheça dicas que vão te ajudar a começar no mundo dos jogos\",\"mensagens\":29},{\"titulo\":\"Tudo sobre RPG\",\"subtitulo\":\"Aprenda e compartilhe suas aventuras de RPG\",\"mensagens\":11},{\"titulo\":\"Análises de jogos\",\"subtitulo\":\"Escreva sua análise ou leia as de outros jogadores\",\"mensagens\":40},{\"titulo\":\"Mods e personalizações\",\"subtitulo\":\"Compartilhe e descubra mods legais\",\"mensagens\":55},{\"titulo\":\"Esports e competições\",\"subtitulo\":\"Fique por dentro de campeonatos e torneios\",\"mensagens\":78},{\"titulo\":\"Memes de games\",\"subtitulo\":\"Divirta-se com memes e piadas de jogos\",\"mensagens\":92},{\"titulo\":\"Game design\",\"subtitulo\":\"Discussão sobre criação e design de jogos\",\"mensagens\":34},{\"titulo\":\"Tutoriais e guias\",\"subtitulo\":\"Aprenda e ensine através de guias e tutoriais\",\"mensagens\":61},{\"titulo\":\"Histórias de jogatina\",\"subtitulo\":\"Compartilhe suas melhores aventuras no jogo\",\"mensagens\":44},{\"titulo\":\"Hardware e periféricos\",\"subtitulo\":\"Converse sobre PCs, consoles e acessórios\",\"mensagens\":88},{\"titulo\":\"Wishlist e recomendações\",\"subtitulo\":\"Dê e receba dicas de jogos para jogar\",\"mensagens\":53}]",
    "payloadType": "json",
    "x": 180,
    "y": 100,
    "wires": [["d475aad8242c7eb1"]]
  },
  {
    "id": "d475aad8242c7eb1",
    "type": "change",
    "z": "206bd8fcaa20b9ee",
    "name": "salvar topicos globais",
    "rules": [
      {
        "t": "set",
        "p": "topics",
        "pt": "global",
        "to": "payload",
        "tot": "msg"
      }
    ],
    "x": 400,
    "y": 100,
    "wires": [[]]
  },
  {
    "id": "4ee4c260abbc0e39",
    "type": "function",
    "z": "206bd8fcaa20b9ee",
    "name": "filtrar topicos",
    "func": "const search = String(msg.payload ?? \"\").trim().toLowerCase();\nconst topics = global.get(\"topics\") || [];\n\nif (!search || search.trim() === \"\") {\n    msg.payload = topics;\n} else {\n    msg.payload = topics.filter(t =>\n        t.titulo.toLowerCase().includes(search) ||\n        t.subtitulo.toLowerCase().includes(search)\n    );\n}\n\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 370,
    "y": 160,
    "wires": [["0a2948258653498a"]]
  },
  {
    "id": "0a2948258653498a",
    "type": "ui_template",
    "z": "206bd8fcaa20b9ee",
    "group": "forum-group",
    "name": "exibir topicos",
    "order": 8,
    "width": 18,
    "height": 9,
    "format": "<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  body,\n  .topics-container,\n  .topic-card,\n  .topic-card-content,\n  h3,\n  p,\n  small,\n  button {\n    font-family: 'Nunito', sans-serif !important;\n  }\n\n  .topics-container {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 15px;\n  }\n\n  .topic-card {\n    flex: 1 1 calc(50% - 15px);\n    border: 1px solid #00830C;\n    border-radius: 25px;\n    background-color: #BBDDBE !important;\n    padding: 10px;\n    color: #005C08 !important;\n    display: flex;\n    gap: 10px;\n    cursor: pointer;\n    transition: transform 0.3s ease-in-out;\n    box-sizing: border-box;\n    min-width: 200px;\n  }\n\n  .topic-card:hover {\n    transform: scale(1.02);\n    border: 2px solid;\n  }\n\n  .topic-card i {\n    font-size: 36px;\n    color: #005C08 !important;\n    margin: 8px 4px 4px 4px;\n    flex-shrink: 0;\n  }\n\n  .topic-card-content {\n    display: flex;\n    flex-direction: column;\n    flex: 1 1 0;\n    min-width: 0;\n  }\n\n  .topic-card-content h3 {\n    margin: 0;\n    font-size: 16px;\n    line-height: 1.2;\n    color: #005C08 !important;\n    background: transparent !important;\n  }\n\n  .topic-card-content p {\n    margin: 4px 0;\n    font-size: 13px;\n    color: #005C08 !important;\n    background: transparent !important;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n\n  .topic-card-content small {\n    font-size: 11px;\n    color: #005C08 !important;\n    opacity: 0.8;\n    background: transparent !important;\n  }\n\n  @media (max-width: 900px) {\n    .topic-card {\n      flex: 1 1 100%;\n    }\n  }\n\n  .ver-mais-btn {\n    margin: 20px auto;\n    padding: 8px 32px;\n    border: none;\n    background: #00830C;\n    color: #fff;\n    border-radius: 12px;\n    cursor: pointer;\n    font-size: 14px;\n    display: block;\n  }\n\n  .ver-mais-btn:hover {\n    background: #005C08;\n  }\n</style>\n\n<div class=\"topics-container\">\n  <div ng-repeat=\"t in msg.payload | limitTo: numVisible\" class=\"topic-card\">\n    <i class=\"fa fa-comment\"></i>\n    <div class=\"topic-card-content\">\n      <h3>{{t.titulo}}</h3>\n      <p>{{t.subtitulo}}</p>\n      <small>Mensagens: {{t.mensagens}}</small>\n    </div>\n  </div>\n</div>\n\n<button class=\"ver-mais-btn\" ng-if=\"numVisible < msg.payload.length\" ng-click=\"showMore()\">\n  Ver mais\n</button>\n\n<script>\n  (function(scope){\n    scope.numVisible = 8;\n\n    scope.showMore = function() {\n        scope.numVisible = Math.min(scope.numVisible + 8, scope.msg.payload.length);\n        scope.$applyAsync();\n    };\n})(scope);\n</script>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 560,
    "y": 160,
    "wires": [[]]
  },
  {
